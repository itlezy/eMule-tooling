#!/bin/sh
# eMule-tooling editorconfig hook
repo_root=$(git rev-parse --show-toplevel 2>/dev/null) || exit 1
hook_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd) || exit 1
hook_runner="$hook_dir/../helpers/git-pre-commit-editorconfig.ps1"
if command -v pwsh >/dev/null 2>&1; then
  exec pwsh -NoLogo -NoProfile -ExecutionPolicy Bypass -File "$hook_runner" -RepoRoot "$repo_root"
fi
echo "pwsh 7.2+ is required for the eMule-tooling editorconfig hook." >&2
exit 1
